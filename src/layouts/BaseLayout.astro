---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DomainCTA from '../components/DomainCTA.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishDate?: string;
  modifiedDate?: string;
  schema?: object[];
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...props} />
  </head>
  <body>
    <div class="sticky-top" id="sticky-top">
      <DomainCTA />
      <Header />
    </div>
    <script is:inline>
      // Keep nav open on desktop (so ul stays in layout flow) and closed on
      // mobile (so burger controls it). Re-sync on viewport changes.
      (function() {
        var mq = window.matchMedia('(min-width: 768px)');
        function sync() {
          var nav = document.querySelector('.nav-disclosure');
          if (!nav) return;
          if (mq.matches) nav.setAttribute('open', '');
          else nav.removeAttribute('open');
        }
        sync();
        mq.addEventListener('change', sync);
      })();
    </script>
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function() {
        var el = document.getElementById('sticky-top');
        var lastY = 0;
        var upDistance = 0;
        var minimized = false;
        var UP_THRESHOLD = 150;
        function onScroll() {
          var y = window.scrollY;
          var delta = y - lastY;
          lastY = y;
          if (y <= 10) {
            upDistance = 0;
            if (minimized) { minimized = false; el.classList.remove('scrolled'); }
            return;
          }
          if (delta > 0) {
            upDistance = 0;
            if (!minimized && y > 40) { minimized = true; el.classList.add('scrolled'); }
          } else {
            upDistance -= delta;
            if (minimized && upDistance > UP_THRESHOLD) { minimized = false; el.classList.remove('scrolled'); }
          }
        }
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
      // Track Make an Offer clicks
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[href*="forsale.godaddy.com"]');
        if (!link) return;
        var location = link.dataset.cta || link.closest('.article-cta') && 'article' || 'unknown';
        var page = window.location.pathname;
        if (typeof gtag === 'function') {
          gtag('event', 'make_offer_click', {
            event_category: 'domain_sale',
            event_label: location + ' | ' + page,
            transport_type: 'beacon'
          });
        }
      });
    </script>
  </body>
</html>
