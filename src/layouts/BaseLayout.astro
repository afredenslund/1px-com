---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DomainCTA from '../components/DomainCTA.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishDate?: string;
  modifiedDate?: string;
  schema?: object[];
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...props} />
  </head>
  <body>
    <div class="sticky-top" id="sticky-top">
      <DomainCTA />
      <Header />
    </div>
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function() {
        var top = document.getElementById('sticky-top');
        var scrolled = false;
        function onScroll() {
          var s = window.scrollY > 40;
          if (s !== scrolled) {
            scrolled = s;
            top.classList.toggle('scrolled', s);
          }
        }
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>
  </body>
</html>
