const publishDate = '2026-04-16';

const domainAge = Math.floor((Date.now() - new Date('2002-05-04').getTime()) / (1000 * 60 * 60 * 24 * 365.25));

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "About 1px.com: A 24-Year-Old Premium 3-Character Domain",
    "description": "Domain profile for 1px.com — registered May 4, 2002. A rare 3-character .com with deep roots in web development history.",
    "image": "https://1px.com/og-image.png",
    "datePublished": publishDate,
    "dateModified": publishDate,
    "author": { "@type": "Organization", "name": "1px.com", "url": "https://1px.com" },
    "publisher": { "@type": "Organization", "name": "1px.com", "url": "https://1px.com" },
    "mainEntityOfPage": "https://1px.com/about-this-domain/",
  },
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "1px.com",
    "description": "Premium 3-character .com domain name with 24 years of registration history and inherent meaning in web development.",
    "url": "https://1px.com/about-this-domain/",
    "brand": { "@type": "Brand", "name": "1px.com" },
    "offers": {
      "@type": "Offer",
      "url": "https://forsale.godaddy.com/forsale/1px.com",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
    }
  }
];

const relatedArticles = [
  {
    href: '/spacer-gif-history/',
    title: 'The Spacer GIF Story',
    description: 'The history behind the 1px reference — the invisible pixel that built the web.',
  },
  {
    href: '/power-of-one/',
    title: 'The Power of 1',
    description: 'Why single-character domains and the number one command premium value.',
  },
  {
    href: '/1px-css-borders/',
    title: '1px Borders in CSS',
    description: 'How 1px remains the most written CSS value in modern web development.',
  },
];
