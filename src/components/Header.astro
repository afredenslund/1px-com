---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: '1px.com' },
  { href: '/history/', label: 'History' },
  { href: '/spacer-gif-history/', label: 'Spacer GIF' },
  { href: '/1px-css-borders/', label: '1px Borders' },
  { href: '/px-unit-explained/', label: 'PX Unit' },
  { href: '/power-of-one/', label: 'Power of 1' },
  { href: '/about-this-domain/', label: 'About Domain' },
];
---

<header class="site-header">
  <nav aria-label="Main navigation">
    <details class="nav-disclosure" open>
      <summary aria-label="Toggle menu">
        <span class="nav-burger" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
        <span class="nav-label">Menu</span>
      </summary>
      <ul>
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[{ active: currentPath === href }]}
              aria-current={currentPath === href ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </details>
  </nav>
</header>

<script is:inline>
  // Slide a subtle indicator line from the active nav item to whichever
  // link the user hovers over, then slide back on leave.
  (function () {
    var ul = document.querySelector('.site-header nav ul');
    if (!ul) return;
    var links = ul.querySelectorAll('a');
    var active = ul.querySelector('a.active');

    var moveTo = function (el, visible) {
      ul.style.setProperty('--nav-indicator-left', el.offsetLeft + 'px');
      ul.style.setProperty('--nav-indicator-width', el.offsetWidth + 'px');
      ul.style.setProperty('--nav-indicator-opacity', visible ? '1' : '0');
    };

    if (active) moveTo(active, false);

    links.forEach(function (a) {
      a.addEventListener('mouseenter', function () {
        moveTo(a, !a.classList.contains('active'));
      });
      a.addEventListener('focus', function () {
        moveTo(a, !a.classList.contains('active'));
      });
    });

    ul.addEventListener('mouseleave', function () {
      if (active) moveTo(active, false);
    });

    window.addEventListener('resize', function () {
      if (active) moveTo(active, false);
    });
  })();
</script>
